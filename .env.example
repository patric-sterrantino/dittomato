# Anthropic — for Magic Translate (browser app)
ANTHROPIC_API_KEY=sk-ant-...

# Firebase — string storage (migrate.js + harvest.js, via a service account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Ditto — only needed for the one-time migration (node migrate.js, without --from-json)
DITTO_API_KEY=your_ditto_key_here
